{
  "info": {
    "_postman_id": "proyecto-empleados-api-collection",
    "name": "Proyecto Empleados API",
    "description": "Colección Postman para probar la API REST de empleados.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Listar Empleados",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:8000/api/empleados/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "empleados", ""]
        },
        "description": "Obtiene la lista de todos los empleados registrados."
      },
      "response": []
    },
    {
      "name": "2. Crear Empleado",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Juan Pérez\",\n  \"departamento\": \"Tecnología\",\n  \"sueldo\": 3500000.00\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/empleados/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "empleados", ""]
        },
        "description": "Crea un nuevo empleado con nombre, departamento y sueldo en COP."
      },
      "response": []
    },
    {
      "name": "3. Obtener Detalles (ID 1)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "http://localhost:8000/api/empleados/1/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "empleados", "1", ""]
        },
        "description": "Obtiene los detalles de un empleado específico por su ID."
      },
      "response": []
    },
    {
      "name": "4. Actualizar Empleado (PUT)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"María López\",\n  \"departamento\": \"Finanzas\",\n  \"sueldo\": 4200000.00\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/empleados/1/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "empleados", "1", ""]
        },
        "description": "Actualiza todos los campos de un empleado existente."
      },
      "response": []
    },
    {
      "name": "5. Actualizar Parcialmente (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sueldo\": 3800000.00\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/empleados/1/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "empleados", "1", ""]
        },
        "description": "Actualiza parcialmente un empleado (solo los campos enviados)."
      },
      "response": []
    },
    {
      "name": "6. Eliminar Empleado",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/api/empleados/1/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "empleados", "1", ""]
        },
        "description": "Elimina un empleado por su ID."
      },
      "response": []
    },
